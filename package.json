{
  "name": "lovelive-api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev --env local --local --port 8787",
    "dev:live": "wrangler dev --env local --local --port 8787 --var UPSTREAM_MODE:live",
    "seed:local": "node scripts/seed-local.mjs",
    "test": "vitest run",
    "smoke:local": "node scripts/smoke-local.mjs",
    "check:data": "node scripts/check-character-data.mjs",
    "check:sources": "node scripts/check-character-sources.mjs",
    "typecheck": "tsc --noEmit",
    "deploy": "node scripts/deploy-cloudflare.mjs --skip-checks",
    "deploy:cf": "node scripts/deploy-cloudflare.mjs",
    "deploy:raw": "wrangler deploy"
  },
  "dependencies": {
    "hono": "^4.8.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250525.0",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4",
    "wrangler": "^4.20.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp",
      "workerd"
    ]
  }
}
